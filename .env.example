# ===== Fifa2026 configuration (copy to .env — do NOT commit .env) =====

# --- bdapps app credentials ---
BDAPPS_APP_ID=APP_13xxxx
BDAPPS_PASSWORD=7af5a4fff0d8658b9d92xxxxxxxxxxxx
BDAPPS_APP_NAME=Fifa2026
# applicationHash from the bdapps portal. Leave blank to fall back to APP_NAME.
BDAPPS_APP_HASH=

# --- Database (MySQL) ---
# 1) In cPanel: create a MySQL database + user, and import database/goaljeto.sql.
# 2) Fill these with the cPanel values. Host is almost always 'localhost'.
DB_HOST=localhost
DB_NAME=cpaneluser_goaljeto
DB_USER=cpaneluser_goaljeto
DB_PASS=

# --- Admin secret ---
# Guards /sync_matches.php and /settle.php. Whoever has this token can enter
# match results and therefore decide who wins prizes. Generate a long random
# value, e.g.:  php -r "echo bin2hex(random_bytes(24));"
# Leave BLANK to disable the web entrypoints (you can still run them from CLI).
ADMIN_TOKEN=

# --- Timezone that data/schedule.php kickoff times are written in ---
APP_TIMEZONE=Asia/Dhaka
