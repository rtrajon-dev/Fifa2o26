# Secrets — never commit real credentials
.env

# Database files. GoalJeeto runs on MySQL and database/goaljeto.sql is the schema,
# so that one IS committed. Local dumps and leftover SQLite files are not.
database/*.sqlite
database/*.sqlite-journal
database/*.db
database/backup*.sql

# Session files (server-generated, never commit) — but keep directory infrastructure
sessions/sess_*
sessions/php_sess_*

# Sensitive / generated files written by the bdapps scripts at runtime
# (OTPs, phone numbers, request/response dumps — never commit these)
bdapps/*.txt
bdapps/*.log
*.txt
*.log

# OS / editor cruft
.DS_Store
Thumbs.db
